# ============================================================
# XM Affiliate SNS Auto Poster - 環境変数設定
# ============================================================
# このファイルを .env にコピーして、各値を設定してください。
# cp .env.example .env

# ============================================================
# MT5 設定
# ============================================================
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=XMTrading-MT5
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ============================================================
# MT4 設定（CSVファイル出力ディレクトリ）
# ============================================================
MT4_CSV_DIR=C:\Users\User\AppData\Roaming\MetaQuotes\Terminal\{TERMINAL_ID}\MQL4\Files

# ============================================================
# X (Twitter) API
# ============================================================
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
X_BEARER_TOKEN=your_x_bearer_token

# ============================================================
# Instagram API
# ============================================================
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_USER_ID=your_instagram_user_id

# ============================================================
# Threads API
# ============================================================
THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id

# ============================================================
# TikTok API
# ============================================================
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# ============================================================
# LINE Messaging API
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_GROUP_ID=your_line_group_id

# ============================================================
# LINE オープンチャット誘導URL
# ============================================================
LINE_OPENCHAT_URL=https://line.me/ti/g2/xxxxx

# ============================================================
# 投稿スケジュール（24時間形式）
# ============================================================
POST_SCHEDULE_HOUR=7
POST_SCHEDULE_MINUTE=0

# ============================================================
# 画像テンプレート
# ============================================================
TEMPLATE_IMAGE=default_template.png

# ============================================================
# ハッシュタグ
# ============================================================
HASHTAGS=#FX #XM #トレード結果 #自動売買 #海外FX #XMアフィリエイト

# ============================================================
# ConoHa オブジェクトストレージ
# ============================================================
CONOHA_ACCESS_KEY=your_conoha_access_key
CONOHA_SECRET_KEY=your_conoha_secret_key
CONOHA_BUCKET_NAME=sns-images
CONOHA_ENDPOINT_URL=https://s3.c3j1.conoha.io
CONOHA_PUBLIC_BASE_URL=

# ============================================================
# Stripe 決済
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================================
# SaaS バックエンドAPI
# ============================================================
BACKEND_API_URL=https://api.yourdomain.com
USER_API_KEY=your_user_api_key
